<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= title || 'Bolillosos Login ✦' %></title>

    <%# ── Theme ── %>
    <link rel="stylesheet" href="/retro-cute.css" />

    <%# ── Page-specific overrides (optional) ── %>
    <style>
        .login-window { max-width: 420px; }
    </style>
</head>
<body>

    <%# ── Floating decorations ── %>
    <span class="rc-deco" style="top:8%;left:6%;animation-delay:0s"      aria-hidden="true">✦</span>
    <span class="rc-deco" style="top:15%;right:8%;animation-delay:1.2s"  aria-hidden="true">♡</span>
    <span class="rc-deco" style="bottom:20%;left:10%;animation-delay:.6s" aria-hidden="true">★</span>
    <span class="rc-deco" style="bottom:12%;right:7%;animation-delay:1.8s"aria-hidden="true">✿</span>
    <span class="rc-deco" style="top:45%;left:3%;animation-delay:.3s"    aria-hidden="true">◇</span>
    <span class="rc-deco" style="top:55%;right:3%;animation-delay:2.1s"  aria-hidden="true">✦</span>

    <%# ── Page wrapper ── %>
    <main class="rc-center">

        <%# ── Window card ── %>
        <div class="rc-window login-window">

        <%# Title bar %>
        <div class="rc-window-bar" aria-hidden="true">
            <span class="rc-dot rc-dot--red"></span>
            <span class="rc-dot rc-dot--yellow"></span>
            <span class="rc-dot rc-dot--green"></span>
            <span class="rc-window-title">♡ Bienvenida Amor Mio</span>
        </div>

        <div class="rc-window-body">

            <%# ── Avatar ── %>
            <div class="rc-avatar-wrap">
            <% if (typeof avatarUrl !== 'undefined' && avatarUrl) { %>
                <img
                class="rc-avatar"
                src="<%= avatarUrl %>"
                alt="<%= typeof username !== 'undefined' ? username + ' avatar' : 'profile picture' %>"
                />
            <% } else { %>
                <div class="rc-avatar-fallback" aria-hidden="true">🌸</div>
            <% } %>
            <div class="rc-avatar-badge" aria-hidden="true">✦</div>
            </div>

            <%# ── Welcome text ── %>
            <div>
            <p class="rc-title">Preciosa!</p>
            <div class="pb-1"></div>
            <p class="rc-subtitle" style="margin-top:-0.75rem;">Accede para continuar ✦</p>
            </div>

            <%# ── Server error alert ── %>
            <% if (typeof error !== 'undefined' && error) { %>
            <div class="rc-alert rc-alert--error" role="alert">
                <span aria-hidden="true">✕</span>
                <span><%= Error %></span>
            </div>
            <% } %>

            <%# ── Login form ── %>
            <form action="/login" method="POST" novalidate style="width:100%;display:flex;flex-direction:column;gap:.85rem;">

            <%# CSRF (csurf / other middleware) %>
            <% if (typeof csrfToken !== 'undefined') { %>
                <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
            <% } %>

            <%# Username %>
            <div class="rc-field">
                <label class="rc-label" for="username">// Nombre de Usuario</label>
                <div class="rc-input-wrap">
                <input
                    class="rc-input"
                    type="text"
                    id="username"
                    name="username"
                    placeholder="Bolillo"
                    value="<%= typeof formUsername !== 'undefined' ? formUsername : '' %>"
                    required
                />
                </div>
            </div>

            <%# Password %>
            <div class="rc-field">
                <label class="rc-label" for="password">// Contraseña</label>
                <div class="rc-input-wrap">
                <input
                    class="rc-input"
                    type="password"
                    id="password"
                    name="password"
                    placeholder="♡ ♡ ♡ ♡ ♡ ♡"
                    required
                />
                <button
                    type="button"
                    class="rc-eye-btn"
                    id="togglePwd"
                    aria-label="Mostrar / Ocultar Contraseña"
                    aria-pressed="false"
                >
                    <svg id="eyeIcon" xmlns="http://www.w3.org/2000/svg" width="18" height="18"
                        viewBox="0 0 24 24" fill="none" stroke="currentColor"
                        stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
                    <circle cx="12" cy="12" r="3"/>
                    </svg>
                </button>
                </div>
            </div>

        <!-- <%# Remember me %>
        <div class="rc-check-row">
            <input type="checkbox" id="remember" name="remember" />
            <label for="remember">Recuerdame ✦</label>
        </div> -->

            <%# Submit %>
            <button type="submit" class="rc-btn rc-btn--pink rc-btn--full">
                Entrar ✦
            </button>

            </form>

            <!-- <div class="rc-divider">or</div> -->

            <p class="rc-sparkle" aria-hidden="true">✦ ♡ ✦ ♡ ✦</p>

        </div><%# /rc-window-body %>
        </div><%# /rc-window %>

    </main>

    <script>
        const toggle   = document.getElementById('togglePwd');
        const pwdInput = document.getElementById('password');
        const eyeIcon  = document.getElementById('eyeIcon');

        const eyeOpen = `
        <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
        <circle cx="12" cy="12" r="3"/>
        `;
        const eyeSlash = `
        <path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8
                a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1
                12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19
                m-6.72-1.07a3 3 0 1 1-4.24-4.24"/>
        <line x1="1" y1="1" x2="23" y2="23"/>
        `;

        toggle.addEventListener('click', () => {
        const hidden = pwdInput.type === 'password';
        pwdInput.type          = hidden ? 'text' : 'password';
        eyeIcon.innerHTML      = hidden ? eyeSlash : eyeOpen;
        toggle.setAttribute('aria-pressed', hidden ? 'true' : 'false');
        toggle.setAttribute('aria-label',   hidden ? 'Hide password' : 'Show password');
        });
    </script>

</body>
</html>
